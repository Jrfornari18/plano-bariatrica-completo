# BodyScan KB — Variáveis de ambiente (NÃO commitar .env com valores reais)
# Copie para .env e preencha os valores

# Banco de dados
DATABASE_URL=postgresql://postgres:@localhost/bodyscan_kb

# OpenAI (embeddings e geração)
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Dimensão do embedding (deve bater com schema.sql vector(N))
EMBED_DIM=1536

# API
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
