# BodyScan KB & Memory — variáveis de ambiente
# Copie para .env e preencha os valores. NUNCA versione o .env real.

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_NAME="BodyScan KB & Memory"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ── Banco de dados ─────────────────────────────────────────────────────────────
# MVP (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./bodyscan_kb.db
# Produção (PostgreSQL + pgvector):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bodyscan_kb

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Opções: mock | sentence_transformers | openai
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL_VERSION=v1

# Para OpenAI embeddings (text-embedding-3-small → dim=1536):
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
# OPENAI_API_KEY=sk-...  ← nunca commitar este valor

# ── RAG ────────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70

# ── Sessão ─────────────────────────────────────────────────────────────────────
SESSION_TTL_MINUTES=60

# ── CORS ───────────────────────────────────────────────────────────────────────
# Em produção, restringir às origens permitidas
CORS_ORIGINS=["*"]
