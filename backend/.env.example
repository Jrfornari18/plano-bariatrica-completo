# Banco
DATABASE_PATH=app/db/knowledge_base.db

# Embeddings (local — sem custo por chamada)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
VECTOR_BACKEND=faiss        # faiss | sqlite-vec

# LLM (geração) — preencher no ambiente, NUNCA no repositório
LLM_PROVIDER=               # ex.: openai | anthropic | openai_compatible
LLM_MODEL=                  # ex.: gpt-4o-mini | claude-3-haiku-20240307
LLM_API_KEY=                # injetada via secret do Railway
LLM_BASE_URL=               # opcional: base URL para providers compatíveis com OpenAI
LLM_TIMEOUT_SECONDS=20

# API
CORS_ORIGINS=https://<seu-front>.vercel.app
RATE_LIMIT_PER_MINUTE=30
LOG_LEVEL=INFO
